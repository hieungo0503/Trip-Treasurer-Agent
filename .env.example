# ============================================================
# Trip Treasurer Agent — Environment Variables
# Copy file này thành .env và điền giá trị thật
# KHÔNG commit file .env vào git
# ============================================================

# ===== Zalo OA =====
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_OA_ID=
ZALO_OA_ACCESS_TOKEN=
ZALO_OA_REFRESH_TOKEN=
# Webhook URL public của server (cần HTTPS)
ZALO_WEBHOOK_URL=https://your-server.com/webhook/zalo

# ===== LLM (Viettel Netmind, OpenAI-compatible) =====
LLM_PROVIDER=viettel
LLM_BASE_URL=https://netmind.viettel.vn/codev
LLM_API_KEY=
LLM_MODEL=openai/gpt-oss-120b
LLM_TIMEOUT_SECONDS=15
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.1

# ===== Google =====
# Path tuyệt đối tới JSON key của service account
GOOGLE_SERVICE_ACCOUNT_JSON=/secrets/google-service-account.json
# ID của Google Sheet dùng làm template (copy cho mỗi trip mới)
GOOGLE_SHEET_TEMPLATE_ID=
# ID của Google Drive folder chứa tất cả sheet trips
GOOGLE_SHEET_PARENT_FOLDER_ID=
# ID của Google Drive folder chứa backup offsite
BACKUP_DRIVE_FOLDER_ID=

# ===== Database =====
# SQLite: sqlite+aiosqlite:////path/to/db
# PostgreSQL: postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:////data/agent.db

# ===== Agent config =====
# Danh sách member_id là admin (comma-separated)
ADMIN_MEMBER_IDS=M001
# Timezone
TIMEZONE=Asia/Ho_Chi_Minh
# Giới hạn chờ xác nhận pending (phút)
PENDING_EXPIRY_MINUTES=30
# Max số ký tự input từ user
MAX_INPUT_LENGTH=500

# ===== Rate limiting =====
RATE_LIMIT_PER_USER_PER_MIN=30
RATE_LIMIT_PER_USER_PER_DAY=500
RATE_LIMIT_LLM_PER_OA_PER_HOUR=100

# ===== Circuit breaker =====
CB_LLM_THRESHOLD=5
CB_LLM_COOLDOWN_SECONDS=120
CB_SHEETS_THRESHOLD=5
CB_SHEETS_COOLDOWN_SECONDS=300
CB_ZALO_THRESHOLD=10
CB_ZALO_COOLDOWN_SECONDS=60

# ===== Observability =====
LOG_LEVEL=INFO
# Options: console, jaeger
OTEL_EXPORTER=console
OTEL_ENDPOINT=http://localhost:4317
PROMETHEUS_PORT=9090

# ===== Backup =====
BACKUP_LOCAL_PATH=/data/backups
BACKUP_ENCRYPTION_KEY_PATH=/secrets/backup-gpg.key
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=12

# ===== Dev/Test =====
# Bật mock channel cho test local (không cần Zalo thật)
MOCK_CHANNEL_ENABLED=false
# Disable LLM gọi thật khi chạy test (dùng mock)
TEST_MODE=false
